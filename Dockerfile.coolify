FROM python:3.11-slim AS base

WORKDIR /app

# System deps for image processing
RUN apt-get update && \
    apt-get install -y --no-install-recommends libgl1 libglib2.0-0 curl && \
    rm -rf /var/lib/apt/lists/*

# Write requirements.txt from base64
RUN echo '' | base64 -d > /app/requirements.txt

# Install Python deps (torch CPU-only from PyTorch index)
RUN pip install --no-cache-dir \
    --extra-index-url https://download.pytorch.org/whl/cpu \
    -r /app/requirements.txt

# Download ML models from BunnyCDN
RUN mkdir -p /app/models && \
    curl -fSL -o /app/models/stage_a_v2_best.pth \
      "https://ds-course.b-cdn.net/stage_a_v2_best.pth" && \
    curl -fSL -o /app/models/stage_b__male.pkl \
      "https://ds-course.b-cdn.net/stage_b__male.pkl" && \
    curl -fSL -o /app/models/stage_b__female.pkl \
      "https://ds-course.b-cdn.net/stage_b__female.pkl"

# Create application code from base64-encoded source
RUN mkdir -p /app/app

# __init__.py (empty)
RUN touch /app/app/__init__.py

# config.py
RUN echo '' | base64 -d > /app/app/config.py

# models.py
RUN echo '' | base64 -d > /app/app/models.py

# dependencies.py
RUN echo '' | base64 -d > /app/app/dependencies.py

# main.py
RUN echo '' | base64 -d > /app/app/main.py

# inference.py (largest file)
RUN echo '' | base64 -d > /app/app/inference.py

ENV MODELS_DIR=/app/models
ENV HOST=0.0.0.0
ENV PORT=8000

EXPOSE 8000

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
